{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/docs/layout,_N_T_/dashboard/docs/docs/layout,_N_T_/dashboard/docs/docs/browser/layout,_N_T_/dashboard/docs/docs/browser/page,_N_T_/dashboard/docs/docs/browser/"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/docs/docs/browser/__PAGE__",
    "/dashboard/docs/docs/browser",
    "/dashboard/docs/docs",
    "/dashboard/docs",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}